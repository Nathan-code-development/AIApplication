<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AITools.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:v="clr-namespace:AITools.Views"
    xmlns:views="clr-namespace:AITools.Views"
    Title="AITools"
    FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
        Title="ModelSquare"
        ContentTemplate="{DataTemplate views:modelSquare}"
        Icon="model_square.png" />
        <ShellContent
        Title="AI"
        ContentTemplate="{DataTemplate views:AI}"
        Icon="ai.png" />
        <ShellContent
        Title="Myself"
        ContentTemplate="{DataTemplate views:Myself}"
        Icon="myself.png" />
    </TabBar>


</Shell>