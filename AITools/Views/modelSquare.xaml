<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AITools.Views.modelSquare"
             Title="modelSquare"
             BackgroundColor="#F5F5F5">
    <ContentPage.Resources>
        <!-- 卡片样式：圆角、浅阴影、白色背景，固定高度形成正方形 -->
        <Style TargetType="Border" x:Key="CardBorderStyle">
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Stroke" Value="#E0E0E0"/>
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="HeightRequest" Value="120"/>
            <!-- 固定高度，与列宽匹配 -->
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="Gray" 
                            Offset="0,1" 
                            Radius="2" 
                            Opacity="0.1" />
                </Setter.Value>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <!-- 使用 Grid 将页面分为三行：标题、内容、底部导航 -->
    <Grid RowDefinitions="Auto, *, Auto">
        <!-- 标题 -->
        <Label Text="AI model square" 
               FontSize="24" 
               FontAttributes="Bold"
               Margin="20,20,20,10"
               HorizontalOptions="Center"
               Grid.Row="0"/>

        <!-- 模型方块网格 (两列) -->
        <CollectionView x:Name="ModelsCollectionView"
                        Grid.Row="1"
                        Margin="20,0,20,10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Span="2" 
                                 Orientation="Vertical" 
                                 HorizontalItemSpacing="10" 
                                 VerticalItemSpacing="10"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" VerticalOptions="Center">
                            <Image Source="{Binding IconSource}" WidthRequest="56" HeightRequest="56"/>
                            <Label Text="{Binding Name}" FontSize="16" TextColor="#333" VerticalTextAlignment="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>