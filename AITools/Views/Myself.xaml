<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AITools.Views.Myself"
             Title="Myself"
             BackgroundColor="#F5F0EB">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ── -->
        <Border Grid.Row="0" BackgroundColor="#1A1A2E" StrokeThickness="0" Padding="20,16,20,18">
            <Border.StrokeShape>
                <RoundRectangle />
            </Border.StrokeShape>
            <Label Text="My Profile" FontSize="20" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

        <!-- ── Scrollable body ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,20,16,20" Spacing="14">

                <!-- ── User info card ── -->
                <Border BackgroundColor="White" Stroke="#E8E4F0" StrokeThickness="1" Padding="16,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8" Opacity="0.10"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="80,*" ColumnSpacing="14">

                        <!-- ── Avatar (tappable) ── -->
                        <Grid Grid.Column="0"
                              WidthRequest="68" HeightRequest="68"
                              HorizontalOptions="Center" VerticalOptions="Center">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                            </Grid.GestureRecognizers>

                            <!-- Circular clip border -->
                            <Border x:Name="AvatarBorder"
                                    BackgroundColor="#E8E4F0"
                                    WidthRequest="68" HeightRequest="68"
                                    StrokeThickness="2" Stroke="#D0C8F0">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>

                                <!-- Placeholder emoji (shown when no avatar) -->
                                <Label x:Name="AvatarPlaceholder"
                                       Text="👤" FontSize="30"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       IsVisible="True"/>
                            </Border>

                            <!-- Real avatar image (overlaid, hidden until loaded) -->
                            <Border WidthRequest="68" HeightRequest="68"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Image x:Name="AvatarImage"
                                       Aspect="AspectFill"
                                       WidthRequest="68" HeightRequest="68"
                                       IsVisible="False"/>
                            </Border>

                            <!-- Camera badge (bottom-right) -->
                            <Border WidthRequest="22" HeightRequest="22"
                                    BackgroundColor="#1A1A2E"
                                    StrokeThickness="2" Stroke="White"
                                    HorizontalOptions="End" VerticalOptions="End"
                                    Margin="0,0,0,0">
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="📷" FontSize="10"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>

                            <!-- Upload overlay spinner -->
                            <ActivityIndicator x:Name="AvatarUploadSpinner"
                                               IsRunning="False" IsVisible="False"
                                               Color="White"
                                               WidthRequest="30" HeightRequest="30"
                                               HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Grid>

                        <!-- Username + User ID -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="6">
                            <Label x:Name="UsernameLabel" Text="—"
                                   FontSize="17" FontAttributes="Bold" TextColor="#1A1A2E"/>
                            <Border BackgroundColor="#F0EEF8" StrokeThickness="0" Padding="8,3">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label x:Name="UserIdLabel" Text="User ID: —"
                                       FontSize="12" TextColor="#8888A0"/>
                            </Border>
                            <!-- Tap-hint -->
                            <Label Text="Tap avatar to change photo"
                                   FontSize="11" TextColor="#B0A8C8"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ── Complete profile ── -->
                <Border BackgroundColor="White" Stroke="#E8E4F0" StrokeThickness="1" Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.08"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCompleteProfileTapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                        <Label Grid.Column="0" Text="✏️" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Complete My Profile" FontSize="15" TextColor="#1A1A2E"
                               VerticalOptions="Center" Margin="10,0,0,0"/>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ── Clear chat history ── -->
                <Border BackgroundColor="White" Stroke="#E8E4F0" StrokeThickness="1" Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.08"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearChatTapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                        <Label Grid.Column="0" Text="🗑️" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Clear Chat History" FontSize="15" TextColor="#E94560"
                               VerticalOptions="Center" Margin="10,0,0,0"/>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ── Recent Topics label ── -->
                <Label Text="Recent Topics" FontSize="13" TextColor="#8888A0" Margin="4,6,0,0"/>

                <!-- ── Topics card ── -->
                <Border BackgroundColor="White" Stroke="#E8E4F0" StrokeThickness="1" Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">

                        <ActivityIndicator x:Name="TopicsLoadingIndicator"
                                           IsRunning="True" IsVisible="True"
                                           Color="#1A1A2E" HorizontalOptions="Center" Margin="0,20"/>

                        <VerticalStackLayout x:Name="TopicsEmptyState" IsVisible="False" Padding="20,24" Spacing="8">
                            <Label Text="💬" FontSize="32" HorizontalOptions="Center"/>
                            <Label Text="No conversations yet" FontSize="14" TextColor="#8888A0" HorizontalOptions="Center"/>
                            <Label Text="Start a chat with AI to see your topics here"
                                   FontSize="12" TextColor="#B0A8C8" HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>

                        <VerticalStackLayout x:Name="TopicsContainer" Spacing="0"/>

                        <Grid x:Name="MoreTopicsRow" ColumnDefinitions="Auto,*,Auto"
                              Padding="16,14" IsVisible="False">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMoreTopicsTapped"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" BackgroundColor="#F0EEF8"
                                    WidthRequest="32" HeightRequest="32" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="⋯" FontSize="16" TextColor="#8888A0"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label x:Name="MoreTopicsLabel" Text="View all topics…"
                                       FontSize="14" TextColor="#8888A0"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Logout ── -->
                <Border BackgroundColor="#1A1A2E" StrokeThickness="0" Padding="0" Margin="0,6,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#401A1A2E" Offset="0,4" Radius="12" Opacity="0.25"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Log Out" FontSize="16" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" Padding="0,16"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
