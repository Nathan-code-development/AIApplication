<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AITools.Views.Myself"
             Title="Myself"
             BackgroundColor="#F5F0EB">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <Border Grid.Row="0"
                BackgroundColor="#1A1A2E"
                StrokeThickness="0"
                Padding="20,16,20,18">
            <Border.StrokeShape>
                <RoundRectangle />
            </Border.StrokeShape>
            <Label Text="My Profile"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Border>

        <!-- ── Main scroll area ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,20,16,20" Spacing="14">

                <!-- ── User info card ── -->
                <Border BackgroundColor="White"
                        Stroke="#E8E4F0"
                        StrokeThickness="1"
                        Padding="16,14">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8" Opacity="0.10"/>
                    </Border.Shadow>

                    <Grid ColumnDefinitions="70,*" ColumnSpacing="14">

                        <!-- Avatar placeholder -->
                        <Border Grid.Column="0"
                                BackgroundColor="#E8E4F0"
                                WidthRequest="62"
                                HeightRequest="62"
                                StrokeThickness="2"
                                Stroke="#D0C8F0"
                                VerticalOptions="Center"
                                HorizontalOptions="Center">
                            <Border.StrokeShape>
                                <Ellipse/>
                            </Border.StrokeShape>
                            <Label Text="👤"
                                   FontSize="28"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <!-- Username + User ID (populated in code-behind) -->
                        <VerticalStackLayout Grid.Column="1"
                                             VerticalOptions="Center"
                                             Spacing="6">
                            <Label x:Name="UsernameLabel"
                                   Text="—"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#1A1A2E"/>
                            <Border BackgroundColor="#F0EEF8"
                                    StrokeThickness="0"
                                    Padding="8,3">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label x:Name="UserIdLabel"
                                       Text="User ID: —"
                                       FontSize="12"
                                       TextColor="#8888A0"/>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ── Complete profile button ── -->
                <Border BackgroundColor="White"
                        Stroke="#E8E4F0"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.08"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCompleteProfileTapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                        <Label Grid.Column="0" Text="✏️" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Complete My Profile"
                               FontSize="15"
                               TextColor="#1A1A2E"
                               VerticalOptions="Center"
                               Margin="10,0,0,0"/>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ── Clear chat history button ── -->
                <Border BackgroundColor="White"
                        Stroke="#E8E4F0"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="6" Opacity="0.08"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearChatTapped"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                        <Label Grid.Column="0" Text="🗑️" FontSize="18" VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="Clear Chat History"
                               FontSize="15"
                               TextColor="#E94560"
                               VerticalOptions="Center"
                               Margin="10,0,0,0"/>
                        <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- ── Section: Recent Topics ── -->
                <Label Text="Recent Topics"
                       FontSize="13"
                       TextColor="#8888A0"
                       Margin="4,6,0,0"/>

                <Border BackgroundColor="White"
                        Stroke="#E8E4F0"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,2" Radius="8" Opacity="0.08"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">

                        <!-- Topic 1 -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTopicTapped" CommandParameter="1"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" BackgroundColor="#EEF0FF"
                                    WidthRequest="32" HeightRequest="32" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="💬" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label Text="Topic 1" FontSize="14" FontAttributes="Bold" TextColor="#1A1A2E"/>
                                <Label Text="Tap to view details" FontSize="12" TextColor="#8888A0"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0EEF8" Margin="16,0"/>

                        <!-- Topic 2 -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTopicTapped" CommandParameter="2"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" BackgroundColor="#FFF0F3"
                                    WidthRequest="32" HeightRequest="32" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="🌟" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label Text="Topic 2" FontSize="14" FontAttributes="Bold" TextColor="#1A1A2E"/>
                                <Label Text="Tap to view details" FontSize="12" TextColor="#8888A0"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0EEF8" Margin="16,0"/>

                        <!-- Topic 3 -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnTopicTapped" CommandParameter="3"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" BackgroundColor="#F0FFF4"
                                    WidthRequest="32" HeightRequest="32" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="🔍" FontSize="15" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label Text="Topic 3" FontSize="14" FontAttributes="Bold" TextColor="#1A1A2E"/>
                                <Label Text="Tap to view details" FontSize="12" TextColor="#8888A0"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F0EEF8" Margin="16,0"/>

                        <!-- More Topics -->
                        <Grid ColumnDefinitions="Auto,*,Auto" Padding="16,14">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnMoreTopicsTapped"/>
                            </Grid.GestureRecognizers>
                            <Border Grid.Column="0" BackgroundColor="#F0EEF8"
                                    WidthRequest="32" HeightRequest="32" StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>
                                <Label Text="⋯" FontSize="16" TextColor="#8888A0"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="View all topics…"
                                   FontSize="14" TextColor="#8888A0"
                                   VerticalOptions="Center" Margin="12,0,0,0"/>
                            <Label Grid.Column="2" Text="›" FontSize="20" TextColor="#B0A8C8" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ── Logout button ── -->
                <Border BackgroundColor="#1A1A2E"
                        StrokeThickness="0"
                        Padding="0"
                        Margin="0,6,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#401A1A2E" Offset="0,4" Radius="12" Opacity="0.25"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Log Out"
                           FontSize="16"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           Padding="0,16"/>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
