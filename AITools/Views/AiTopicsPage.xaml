<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AITools.Views.AllTopicsPage"
             Title="All Topics"
             BackgroundColor="#F5F0EB">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#1A1A2E" StrokeThickness="0" Padding="16,16,20,18">
            <Border.StrokeShape>
                <RoundRectangle />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*">
                <Border Grid.Column="0" BackgroundColor="#2A2A4E" Padding="10,6"
                        StrokeThickness="0" VerticalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="‹ Back" FontSize="14" TextColor="White"/>
                </Border>
                <Label Grid.Column="1" Text="All Topics" FontSize="20" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">

            <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True"
                               Color="#1A1A2E" HorizontalOptions="Center" VerticalOptions="Center"/>

            <VerticalStackLayout x:Name="EmptyState" IsVisible="False"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <Label Text="💬" FontSize="48" HorizontalOptions="Center"/>
                <Label Text="No conversations yet" FontSize="16" FontAttributes="Bold"
                       TextColor="#1A1A2E" HorizontalOptions="Center"/>
                <Label Text="Start a chat with AI to see your topics here"
                       FontSize="13" TextColor="#8888A0" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <ScrollView x:Name="TopicsScrollView" IsVisible="False">
                <VerticalStackLayout Padding="16,16,16,24" Spacing="10">
                    <Label x:Name="TopicsCountLabel" Text="" FontSize="13" TextColor="#8888A0" Margin="4,0,0,4"/>
                    <Border BackgroundColor="White" Stroke="#E8E4F0" StrokeThickness="1" Padding="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16"/>
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#20000000" Offset="0,2" Radius="8" Opacity="0.08"/>
                        </Border.Shadow>
                        <VerticalStackLayout x:Name="TopicsContainer" Spacing="0"/>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>
</ContentPage>
