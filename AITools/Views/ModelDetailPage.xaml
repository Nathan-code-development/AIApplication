<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AITools.Views.ModelDetailPage"
             BackgroundColor="#0F0F13"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent"/>
            <Setter Property="TextColor" Value="#556677"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HeightRequest" Value="40"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
        <!-- ROW 0 : Custom title bar -->
        <Grid Grid.Row="0"
              BackgroundColor="#0F0F13"
              HeightRequest="60"
              ColumnDefinitions="48,*,48">
            <Label Grid.Column="1"
                   Text="AI Model Detail"
                   FontSize="18" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>

        <!-- ROW 1 : Hero Banner -->
        <Grid x:Name="HeroBanner"
              Grid.Row="1"
              Padding="16,12,16,20"
              RowDefinitions="Auto,Auto,Auto,Auto">

            <Ellipse Grid.RowSpan="4"
                     Fill="White" Opacity="0.05"
                     WidthRequest="160" HeightRequest="160"
                     HorizontalOptions="End" VerticalOptions="Start"
                     Margin="0,-50,-50,0"/>

            <!-- Back + Like buttons -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,18">
                <Button Grid.Column="0"
                        x:Name="BackButton"
                        Text="&#x2039;"
                        FontSize="22" TextColor="White"
                        BackgroundColor="#33000000"
                        CornerRadius="8"
                        WidthRequest="36" HeightRequest="36"
                        Padding="0"
                        Clicked="OnBackClicked"/>
                <Button Grid.Column="2"
                        x:Name="LikeButton"
                        Text="&#x2661;"
                        FontSize="16" TextColor="White"
                        BackgroundColor="#33000000"
                        CornerRadius="8"
                        WidthRequest="36" HeightRequest="36"
                        Padding="0"
                        Clicked="OnLikeClicked"/>
            </Grid>

            <!-- Model logo + name + rating -->
            <HorizontalStackLayout Grid.Row="1" Spacing="12">
                <Border x:Name="LogoBorder"
                        BackgroundColor="#33FFFFFF"
                        Stroke="#44FFFFFF"
                        StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 15"
                        WidthRequest="56" HeightRequest="56">
                    <Image x:Name="HeroIcon"
                           WidthRequest="38" HeightRequest="38"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label x:Name="HeroName"
                           FontSize="22" FontAttributes="Bold" TextColor="White"/>
                    <Label x:Name="HeroCompany"
                           FontSize="12" TextColor="#CCFFFFFF"/>
                    <HorizontalStackLayout Spacing="5">
                        <Label x:Name="HeroStars" TextColor="#FFB800" FontSize="12"/>
                        <Label x:Name="HeroRating" TextColor="#AABBCC" FontSize="11"
                               VerticalTextAlignment="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <!-- Slogan -->
            <Label x:Name="HeroSlogan"
                   Grid.Row="2"
                   FontSize="12.5" TextColor="#DDEEFF"
                   Margin="0,12,0,0"/>

            <!-- Tag pills -->
            <FlexLayout x:Name="HeroTagsLayout"
                        Grid.Row="3"
                        Wrap="Wrap" Direction="Row"
                        Margin="0,10,0,0"/>
        </Grid>

        <!-- ROW 2 : CTA button -->
        <Button x:Name="CtaButton"
                Grid.Row="2"
                Text="&#x1F680;  Use Now"
                FontSize="15" FontAttributes="Bold"
                TextColor="White" CornerRadius="14"
                HeightRequest="48"
                Margin="16,12,16,0"/>

        <!-- ROW 3 : Tab bar -->
        <Grid Grid.Row="3"
              ColumnDefinitions="*,*,*,*"
              Margin="0,10,0,0"
              BackgroundColor="#0F0F13">

            <Button x:Name="TabOverview"
                    Grid.Column="0" Text="Overview"
                    Style="{StaticResource TabButtonStyle}"
                    Clicked="OnTabClicked" CommandParameter="overview"/>
            <Button x:Name="TabSpecs"
                    Grid.Column="1" Text="Specs"
                    Style="{StaticResource TabButtonStyle}"
                    Clicked="OnTabClicked" CommandParameter="specs"/>
            <Button x:Name="TabCompare"
                    Grid.Column="2" Text="Compare"
                    Style="{StaticResource TabButtonStyle}"
                    Clicked="OnTabClicked" CommandParameter="compare"/>
            <Button x:Name="TabReviews"
                    Grid.Column="3" Text="Reviews"
                    Style="{StaticResource TabButtonStyle}"
                    Clicked="OnTabClicked" CommandParameter="reviews"/>

            <!-- Active indicator underline -->
            <BoxView x:Name="TabIndicator"
                     Grid.Column="0"
                     HeightRequest="2.5" CornerRadius="2"
                     VerticalOptions="End" Margin="12,0"/>

            <!-- Bottom divider -->
            <BoxView Grid.ColumnSpan="4"
                     HeightRequest="0.5" Color="#2A2A38"
                     VerticalOptions="End"/>
        </Grid>

        <!-- ROW 4 : Scrollable content -->
        <ScrollView Grid.Row="4">
            <VerticalStackLayout x:Name="ContentArea"
                                 Padding="16,16,16,32" Spacing="0"/>
        </ScrollView>

    </Grid>
</ContentPage>
