<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AITools.Views.LoginPage"
             BackgroundColor="#F5F0EB">

    <Shell.NavBarIsVisible>False</Shell.NavBarIsVisible>

    <ContentPage.Resources>
        <Style TargetType="ContentPage">
            <Setter Property="BackgroundColor" Value="#F5F0EB"/>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <BoxView BackgroundColor="#1A1A2E" HeightRequest="0"/>

            <!-- ── Page header ── -->
            <VerticalStackLayout BackgroundColor="#F5F0EB"
                                 Padding="20,66,20,28" Spacing="6"
                                 HorizontalOptions="Fill">
                <Border BackgroundColor="#2A2A4E"
                        WidthRequest="60" HeightRequest="60"
                        StrokeThickness="0" HorizontalOptions="Center">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <Label Text="AI" FontSize="24" FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <Label Text="Login" FontSize="22" FontAttributes="Bold"
                       TextColor="Black" HorizontalOptions="Center"/>
                <Label Text="Welcome back to AITools" FontSize="13"
                       TextColor="#A0A0C8" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- ── Form ── -->
            <VerticalStackLayout Padding="28,28,28,32" Spacing="0">

                <Border BackgroundColor="White" Stroke="#E8E4F0"
                        StrokeThickness="1" Padding="24,28">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#20000000" Offset="0,4" Radius="16" Opacity="0.10"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">

                        <!-- Username -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Username" FontSize="13" FontAttributes="Bold" TextColor="#1A1A2E"/>
                            <Border BackgroundColor="#F8F6FF" Stroke="#E0D8F8" StrokeThickness="1.5" Padding="14,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry x:Name="UsernameEntry"
                                       Placeholder="Input username"
                                       PlaceholderColor="#B0A8C8"
                                       TextColor="#1A1A2E" FontSize="15"
                                       BackgroundColor="Transparent"
                                       HeightRequest="50" ReturnType="Next"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Password -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Password" FontSize="13" FontAttributes="Bold" TextColor="#1A1A2E"/>
                            <Border BackgroundColor="#F8F6FF" Stroke="#E0D8F8" StrokeThickness="1.5" Padding="14,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>
                                <Entry x:Name="PasswordEntry"
                                       Placeholder="Input password"
                                       PlaceholderColor="#B0A8C8"
                                       TextColor="#1A1A2E" FontSize="15"
                                       IsPassword="True"
                                       BackgroundColor="Transparent"
                                       HeightRequest="50" ReturnType="Done"
                                       Completed="OnLoginClicked"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Error message -->
                        <Label x:Name="ErrorLabel"
                               Text="" FontSize="13"
                               TextColor="#E94560"
                               IsVisible="False"
                               HorizontalOptions="Center"/>

                        <!-- Login button（With loading status）-->
                        <Border BackgroundColor="#1A1A2E" StrokeThickness="0" Margin="0,8,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLoginClicked"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="*,Auto,*" Padding="0,16">
                                <Label Grid.Column="1"
                                       x:Name="LoginButtonLabel"
                                       Text="Login"
                                       FontSize="16" FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalOptions="Center"/>
                                <ActivityIndicator Grid.Column="1"
                                                   x:Name="LoginLoadingIndicator"
                                                   IsRunning="False" IsVisible="False"
                                                   Color="White"
                                                   HorizontalOptions="Center"/>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- Navigate to register -->
                <Border BackgroundColor="Transparent" Stroke="#D0C8F0"
                        StrokeThickness="1" Margin="0,14,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoToRegisterTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="Don't have an account?  Sign up!"
                           FontSize="14" TextColor="#4A3F8C"
                           HorizontalOptions="Center" Padding="0,14"/>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
